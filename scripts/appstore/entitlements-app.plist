<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Must match the provisioning profile: TEAMID.bundleid and the team id.
       Without these the MAS/TestFlight signature check fails (error 90886). -->
  <key>com.apple.application-identifier</key><string>69NPZWZB47.com.bbrizly.quadstickconfigmanager</string>
  <key>com.apple.developer.team-identifier</key><string>69NPZWZB47</string>
  <!-- Mac App Store requires the sandbox. -->
  <key>com.apple.security.app-sandbox</key><true/>
  <!-- .NET runs a JIT; without this the app crashes at launch in sandbox. -->
  <key>com.apple.security.cs.allow-jit</key><true/>
  <!-- User picks the QuadStick volume/CSV via the folder and file pickers. -->
  <key>com.apple.security.files.user-selected.read-write</key><true/>
  <!-- Sheets import and Drive backup call Google over HTTPS. -->
  <key>com.apple.security.network.client</key><true/>
  <!-- Google sign-in redirects the browser to a loopback listener; the
       sandbox needs the server entitlement for the app to accept it. -->
  <key>com.apple.security.network.server</key><true/>
</dict>
</plist>
