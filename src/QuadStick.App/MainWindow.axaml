<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="QuadStick.App.MainWindow"
        Title="QuadStick Config Manager (unofficial)"
        Width="1180" Height="850" MinWidth="760" MinHeight="560">
  <Panel x:Name="RootPanel">
  <LayoutTransformControl x:Name="ZoomHost"
                          HorizontalAlignment="Left" VerticalAlignment="Top">
  <Panel x:Name="ScaleContent">

    <!-- ============ HOME ============ -->
    <DockPanel x:Name="HomeView" Margin="32,24">
      <DockPanel DockPanel.Dock="Top">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Top">
          <TextBlock Text="Appearance" VerticalAlignment="Center" Classes="secondary"/>
          <ComboBox x:Name="AppearancePicker" MinWidth="130"
                    AutomationProperties.Name="Appearance: choose System, Light, or Dark theme"/>
          <Button x:Name="SettingsButton" Content="⚙ Settings"
                  AutomationProperties.Name="Open Settings"/>
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="QuadStick Config Manager" FontSize="{DynamicResource TitleSize}" FontWeight="Bold"/>
          <TextBlock Text="Edit and install game profiles for your QuadStick. Free, unofficial, works offline."
                     FontSize="{DynamicResource SubheadSize}" Classes="secondary"/>
          <TextBlock x:Name="HomeVersionText" FontSize="{DynamicResource SmallSize}" Classes="secondary"/>
        </StackPanel>
      </DockPanel>

      <ScrollViewer Margin="0,24,0,0">
        <StackPanel Spacing="28">

          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Start"/>
            <WrapPanel x:Name="StartCards">
              <Button x:Name="HomeNewButton" Classes="card"
                      AutomationProperties.Name="Create a new profile from the factory default template">
                <StackPanel Spacing="6">
                  <TextBlock Text="New profile" FontSize="{DynamicResource SectionSize}" FontWeight="Bold"/>
                  <TextBlock Text="Start from the factory default layout" Classes="cardsub"/>
                </StackPanel>
              </Button>
              <Button x:Name="HomeOpenButton" Classes="card"
                      AutomationProperties.Name="Open a profile CSV file from your computer">
                <StackPanel Spacing="6">
                  <TextBlock Text="Open a file" FontSize="{DynamicResource SectionSize}" FontWeight="Bold"/>
                  <TextBlock Text="Edit a profile CSV from anywhere" Classes="cardsub"/>
                </StackPanel>
              </Button>
              <Button x:Name="HomeHelpButton" Classes="card"
                      AutomationProperties.Name="Open the quick guide that explains profiles, outputs, functions, and inputs">
                <StackPanel Spacing="6">
                  <TextBlock Text="How it works" FontSize="{DynamicResource SectionSize}" FontWeight="Bold"/>
                  <TextBlock Text="Profiles, sips, puffs, and installing, in plain words" Classes="cardsub"/>
                </StackPanel>
              </Button>
            </WrapPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBox x:Name="SheetsUrlBox" Width="520"
                       Watermark="Paste a Google Sheets profile link to import"
                       AutomationProperties.Name="Google Sheets profile link"/>
              <Button x:Name="ImportButton" Content="Import from Sheets"
                      AutomationProperties.Name="Import the profile from the pasted Google Sheets link"/>
            </StackPanel>
            <TextBlock x:Name="HomeStatusText" FontSize="{DynamicResource BodySize}" Classes="error"
                       TextWrapping="Wrap" MaxWidth="700" IsVisible="False"
                       AutomationProperties.LiveSetting="Assertive"/>
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="Your profiles"/>
            <StackPanel x:Name="LibraryEmptyPanel" Spacing="10">
              <TextBlock FontSize="{DynamicResource BodySize}" Classes="secondary"
                         Text="Profiles you save will show up here."/>
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button x:Name="LibraryEmptyNewButton" Content="New profile"
                        AutomationProperties.Name="Create a new profile from the factory default template"/>
                <Button x:Name="LibraryEmptyOpenButton" Content="Open a file"
                        AutomationProperties.Name="Open a profile CSV file from your computer"/>
                <Button x:Name="LibraryEmptyImportButton" Content="Import from Sheets"
                        AutomationProperties.Name="Import the profile from the pasted Google Sheets link"/>
              </StackPanel>
            </StackPanel>
            <WrapPanel x:Name="LibraryCards"/>
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="On your QuadStick"/>
            <TextBlock x:Name="DeviceEmptyText" FontSize="{DynamicResource BodySize}" Classes="secondary"
                       Text="Plug in your QuadStick and its profiles will show up here. (In PS4 boot mode or controller emulation? The drive won't appear.)"/>
            <WrapPanel x:Name="DeviceCards"/>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </DockPanel>

    <!-- ============ EDITOR ============ -->
    <DockPanel x:Name="EditorView" Margin="16,16" IsVisible="False">

      <!-- Row 1: back + compact profile name on the left, primary actions on the right. -->
      <Grid DockPanel.Dock="Top" Margin="0,0,0,10" ColumnDefinitions="Auto,Auto,*,Auto">
        <Button x:Name="HomeButton" Grid.Column="0" Content="← Home"
                AutomationProperties.Name="Go back to the home screen"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="14,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="Profile" VerticalAlignment="Center" Classes="secondary"/>
          <TextBox x:Name="FileNameBox" Width="230" FontSize="{DynamicResource SubheadSize}" FontWeight="Bold"
                   VerticalAlignment="Center"
                   AutomationProperties.Name="Profile file name. Edit to rename, must end in .csv"/>
        </StackPanel>
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10">
          <Button x:Name="SaveButton" Content="Save"
                  AutomationProperties.Name="Save this profile. Shortcut Control S"/>
          <Button x:Name="UndoButton" Content="Undo"
                  AutomationProperties.Name="Undo the last change. Shortcut Control Z"/>
          <Button x:Name="InstallButton" Content="Install to QuadStick" Classes="primary"
                  AutomationProperties.Name="Install this profile onto a connected QuadStick. Shortcut Control I"/>
          <Button x:Name="HelpButton" Content="Help"
                  AutomationProperties.Name="Open the quick guide. Shortcut Control H or F1"/>
        </StackPanel>
      </Grid>

      <ContentControl x:Name="StatusHost" DockPanel.Dock="Top" Margin="0,0,0,10"/>

      <!-- Row 2: which mode (with a plain-language explainer), how to view it, add a row. -->
      <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10" VerticalAlignment="Center">
        <TextBlock Text="Mode" VerticalAlignment="Center" FontSize="{DynamicResource BodySize}"/>
        <ComboBox x:Name="SheetPicker" MinWidth="210"
                  AutomationProperties.Name="Select which mode to edit"/>
        <Button x:Name="ModeHelpButton" Classes="icon" Content="?"
                AutomationProperties.Name="What is a mode, and why is there only one?"/>
        <Border Width="1" Background="{DynamicResource SurfaceBorderBrush}" Margin="6,4"/>
        <Button x:Name="DeviceViewButton" Content="Device view"
                AutomationProperties.Name="Show the mappings on a picture of the QuadStick. Shortcut Control D toggles this"/>
        <Button x:Name="ListViewButton" Content="List view"
                AutomationProperties.Name="Show the mappings as a list of rows. Shortcut Control D toggles this"/>
        <Border Width="1" Background="{DynamicResource SurfaceBorderBrush}" Margin="6,4"/>
        <Button x:Name="LabelStyleButton"
                AutomationProperties.Name="Switch the words used in device view between plain English and the raw list-view names"/>
        <Border Width="1" Background="{DynamicResource SurfaceBorderBrush}" Margin="6,4"/>
        <Button x:Name="AddRowButton" Content="+ Add row"
                AutomationProperties.Name="Add a new binding row to this mode"/>
      </StackPanel>

      <!-- Problems: collapsed to a single bar by default so it never eats the
           editor; the full list expands above the bar on demand. -->
      <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
        <Border x:Name="ProblemsListBorder" IsVisible="False" Height="150" Margin="0,0,0,8"
                BorderBrush="{DynamicResource SurfaceBorderBrush}" BorderThickness="1" CornerRadius="8"
                Background="{DynamicResource SurfaceBrush}" BoxShadow="0 1 3 0 #14000000">
          <ListBox x:Name="IssuesList" FontSize="{DynamicResource SmallSize}" Background="Transparent"
                   AutomationProperties.Name="List of validation problems. Select one to copy it."/>
        </Border>
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Button x:Name="ProblemsToggle" Grid.Column="0" Classes="quiet" HorizontalContentAlignment="Left"
                  AutomationProperties.Name="Show or hide the list of problems"/>
          <Button x:Name="FixFirstButton" Grid.Column="2" Content="Fix first problem" Classes="quiet"
                  AutomationProperties.Name="Jump to and focus the first error in the Problems list"/>
        </Grid>
      </StackPanel>

      <Panel>
        <Border x:Name="GridContainer" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12" BoxShadow="0 1 3 0 #14000000">
          <ScrollViewer x:Name="GridScroll">
            <StackPanel x:Name="RowsPanel" Spacing="6"/>
          </ScrollViewer>
        </Border>
        <Border x:Name="DeviceContainer" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1" CornerRadius="8" IsVisible="False" BoxShadow="0 1 3 0 #14000000">
          <DockPanel>
            <Border x:Name="DeviceHeaderRow" DockPanel.Dock="Top" Padding="14,10"
                    BorderBrush="{DynamicResource SurfaceBorderBrush}" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                <ContentControl x:Name="DeviceHeaderStatus" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBlock x:Name="DeviceHeaderMode" Grid.Column="1" Margin="14,0,0,0" Classes="secondary"
                           VerticalAlignment="Center" FontSize="{DynamicResource SmallSize}"/>
                <TextBlock Grid.Column="3" Text="Your QuadStick" Classes="secondary" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontSize="{DynamicResource SmallSize}"/>
                <ComboBox x:Name="ModelPicker" Grid.Column="4" MinWidth="180"
                          AutomationProperties.Name="Which QuadStick model you have"/>
                <Button x:Name="DeviceHelpButton" Grid.Column="5" Classes="icon" Content="?" Margin="10,0,0,0"
                        AutomationProperties.Name="How device view works, and which parts your model has"/>
              </Grid>
            </Border>
            <!-- The mappings panel owns the larger, right-hand share of the
                 editor (like a split terminal): a selected part's mappings get
                 the room to be full-width and readable. The device diagram on
                 the left is sized to fit whole, with no scrolling. -->
            <Grid ColumnDefinitions="1.05*,1.3*">
              <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DeviceCanvas" Margin="14"/>
              </ScrollViewer>
              <Border Grid.Column="1" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource SurfaceBorderBrush}"
                      BorderThickness="1,0,0,0" Padding="18" MinWidth="360">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                  <StackPanel x:Name="ZoneDetailPanel" Spacing="14"/>
                </ScrollViewer>
              </Border>
            </Grid>
          </DockPanel>
        </Border>
      </Panel>

    </DockPanel>
  </Panel>
  </LayoutTransformControl>
  </Panel>
</Window>
